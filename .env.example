# Spotify app credentials. Register at https://developer.spotify.com/dashboard
# IMPORTANT: add http://127.0.0.1:3000/api/auth/callback as a Redirect URI on
# the registered app (the loopback IP literal — `localhost` is no longer
# allowed by Spotify since the November 2025 OAuth migration).
SPOTIFY_CLIENT_ID=

# 32-byte hex string. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Optional overrides
# PORT=3000
# DB_PATH=./altplayer.sqlite
